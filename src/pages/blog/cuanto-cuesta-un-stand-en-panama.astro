      "author": { "@type": "Organization", "name": "ExpoStands Panamá" },
      "datePublished": "2026-05-15",
      "publisher": { "@type": "Organization", "name": "ExpoStands Panamá" },
      "mainEntityOfPage": { "@type": "WebPage", "@id": "https://expostandspanama.com/blog/cuanto-cuesta-un-stand-en-panama" }
    }
  `} />
</BaseLayout>

