      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": "Cómo elegir el acrílico adecuado para tus displays en Panamá",
      "description": "Guía para elegir acrílico para displays: grosores, tipos, acabados y recomendaciones.",
      "author": { "@type": "Organization", "name": "ExpoStands Panamá" },
      "datePublished": "2026-05-02",
      "publisher": { "@type": "Organization", "name": "ExpoStands Panamá" },
      "mainEntityOfPage": { "@type": "WebPage", "@id": "https://expo-stands-panama.netlify.app/blog/como-elegir-acrilico-para-displays" }
    }
  `} />
</BaseLayout>
