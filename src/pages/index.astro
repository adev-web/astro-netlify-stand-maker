---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import Hero from "../components/Hero.astro";
import Services from "../components/Services.astro";
import Materials from "../components/Materials.astro";
import FAQ from "../components/FAQ.astro";
import Projects from "../components/Projects.astro";
import SchemaFAQ from "../components/SchemaFAQ.astro";
---

<BaseLayout
  title="ExpoStands Panamá | Fabricación de stands, exhibidores y mobiliario comercial"
  description="Fabricación profesional de stands feriales, exhibidores comerciales, corte láser en acrílico, letras corpóreas, señalización y mobiliario personalizado en Panamá. Cotiza sin compromiso."
  canonical="/"
  ogType="website"
>
  <Header />
  <main id="main-content">
    <Hero />
    <Services />
    <Projects />
    <Materials />
    <FAQ />
  </main>
  <Footer />
  <WhatsAppButton />

  <SchemaFAQ slot="head" />
</BaseLayout>
