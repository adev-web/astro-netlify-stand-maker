---
const materials = [
  { name: "Acrílico", desc: "Ideal para displays, letreros y expositores transparentes o de colores. Corte láser de alta precisión." },
  { name: "MDF", desc: "Perfecto para muebles comerciales, paneles decorativos y estructuras con acabado premium." },
  { name: "PVC espumado", desc: "Ligero, resistente y fácil de imprimir. Muy usado en stands, letreros y señalización." },
  { name: "Aluminio", desc: "Estructuras modulares, bastidores y perfiles para exhibidores de alta durabilidad." },
  { name: "Vinil", desc: "Impresión de alta calidad para banners, adhesivos, rotulación y gráficos promocionales." },
  { name: "Melamina", desc: "Acabados limpios y resistentes para muebles de exhibición y mobiliario de retail." },
  { name: "Estructuras modulares", desc: "Sistemas tipo panel, tubo y conector para armado rápido de stands feriales." },
];
---

<section class="section" id="materiales" aria-label="Materiales">
  <div class="container">
    <h2 class="section__title">Materiales que trabajamos</h2>
    <p class="section__subtitle">
      Usamos materiales de alta calidad para cada proyecto. Te asesoramos sobre la mejor opción según tu necesidad y presupuesto.
    </p>
    <div class="materials__grid">
      {materials.map((m) => (
        <div class="material-item">
          <h3 class="material-item__name">{m.name}</h3>
          <p class="material-item__desc">{m.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .materials__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
    gap: 1rem;
  }

  .material-item {
    background: var(--color-bg-alt);
    border-radius: var(--radius);
    padding: 1.5rem;
    border-left: 4px solid var(--color-accent);
    transition: all var(--transition);
  }

  .material-item:hover {
    box-shadow: var(--shadow-sm);
    transform: translateX(4px);
  }

  .material-item__name {
    font-size: 1.125rem;
    margin-bottom: 0.375rem;
    color: var(--color-primary);
  }

  .material-item__desc {
    font-size: 0.9375rem;
    color: var(--color-text-light);
    line-height: 1.6;
  }
</style>
