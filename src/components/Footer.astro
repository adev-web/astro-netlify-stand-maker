---
const year = new Date().getFullYear();
---

<footer class="footer" role="contentinfo" id="contacto">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <h3 class="footer__title">ExpoStands Panamá</h3>
        <p class="footer__text">
          Fabricación profesional de stands, exhibidores, mobiliario comercial y corte láser en acrílico en Panamá.
          Transformamos tus ideas en estructuras funcionales y atractivas para ferias, retail y eventos corporativos.
        </p>
      </div>

      <div class="footer__col">
        <h4 class="footer__heading">Servicios</h4>
        <ul class="footer__links">
          <li><a href="/servicios/stands-feriales">Stands feriales</a></li>
          <li><a href="/servicios/exhibidores-comerciales">Exhibidores comerciales</a></li>
          <li><a href="/servicios/corte-acrilico">Corte láser en acrílico</a></li>
          <li><a href="/servicios/letras-corporeas">Letras corpóreas</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h4 class="footer__heading">Blog</h4>
        <ul class="footer__links">
          <li><a href="/blog/cuanto-cuesta-un-stand-en-panama">¿Cuánto cuesta un stand?</a></li>
          <li><a href="/blog/mejores-materiales-para-exhibiciones">Mejores materiales para exhibiciones</a></li>
          <li><a href="/blog/como-elegir-acrilico-para-displays">Cómo elegir acrílico para displays</a></li>
          <li><a href="/blog/ideas-de-stands-modulares">Ideas de stands modulares</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h4 class="footer__heading">Contacto</h4>
        <ul class="footer__contact">
          <li>
