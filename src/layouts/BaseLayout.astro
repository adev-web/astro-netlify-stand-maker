---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  publishedTime?: string;
  author?: string;
  articleSection?: string;
}

const {
  title,
  description,
  canonical,
  ogImage = "/images/og-default.svg",
  ogType = "website",
  publishedTime,
  author,
  articleSection,
} = Astro.props;

import "../styles/global.css";
import { WHATSAPP_NUMBER, SITE_URL } from "../constants";
import SchemaLocalBusiness from "../components/SchemaLocalBusiness.astro";

const site = SITE_URL;
const canonicalUrl = canonical ? `${site}${canonical}` : `${site}/`;
const imageUrl = ogImage.startsWith("http") ? ogImage : `${site}${ogImage}`;

const telephoneNumber = `+${WHATSAPP_NUMBER.slice(0,3)}-${WHATSAPP_NUMBER.slice(3,7)}-${WHATSAPP_NUMBER.slice(7)}`;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content="Astro" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_PA" />
    <meta property="og:site_name" content="ExpoStands Panamá" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <meta name="google-site-verification" content="8vGWNDHUwb6kOhVL8Xi1sEluAcVqLtuKnWQwVVd2kQc" />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow, max-snippet:-1, max-image-preview:large" />

    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {author && <meta property="article:author" content={author} />}
    {articleSection && <meta property="article:section" content={articleSection} />}

    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <link rel="icon" type="image/svg+xml" href="/images/logo-icon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#1a3a52" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="ExpoStands" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" /></noscript>

    <SchemaLocalBusiness site={site} telephone={telephoneNumber} />
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>
    <slot />
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js')
          .then((registration) => {
            console.log('Service Worker registrado:', registration);
          })
          .catch((error) => {
            console.log('Error al registrar Service Worker:', error);
          });
      }
    </script>
  </body>
</html>
